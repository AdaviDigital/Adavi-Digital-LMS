# ==========================================================
# Adavi Digital Institute LMS — Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file to version control.
# ==========================================================

# ---- General ----
NODE_ENV=production

# ---- Database (PostgreSQL) ----
POSTGRES_USER=adavi
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=adavi_lms
DATABASE_URL=postgresql://adavi:change_me_strong_password@postgres:5432/adavi_lms

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- Backend API ----
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=https://adavidigitalinstitute.com

# ---- JWT ----
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ---- Frontend ----
NEXT_PUBLIC_API_URL=https://adavidigitalinstitute.com/api/v1

# ---- AI (OpenAI-compatible pluggable adapter) ----
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ---- Payment Gateways ----
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ---- Email (SMTP) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@adavidigitalinstitute.com

# ---- SMS / WhatsApp ----
WHATSAPP_API_TOKEN=
SMS_API_KEY=

# ---- Uploads ----
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=500

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ---- Logging & Monitoring ----
LOG_LEVEL=info
SENTRY_DSN=
